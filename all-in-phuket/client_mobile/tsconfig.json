{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true
    // "noUncheckedIndexedAccess": true
  },
  "include": ["./src", ".expo/types/**/*.ts", "expo-env.d.ts", "src/__SHARED__"],
  "exclude": ["node_modules"]
}
